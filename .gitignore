# Python cache / build artifacts
__pycache__/
*.py[cod]
*.so
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Data and outputs that can become large
# Keep folders tracked with .gitkeep, but avoid committing large files by default.
data/raw/*.csv
data/raw/*.zip
data/raw/*.parquet
data/raw/*.feather
outputs/models/*
outputs/logs/*

# Allow keepfiles
!data/raw/.gitkeep
!data/raw/README.md
!outputs/models/.gitkeep
!outputs/logs/.gitkeep
